cc:membershipOf a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:TeamMembership ;
  rdfs:range cc:Person ;
  owl:inverseOf cc:hasTeamMembership ;

cc:issuedBy a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:CertificationType ;
  rdfs:range cc:Organization ;
  owl:inverseOf cc:issues ;
  rdfs:label "issued by"@en ;
  rdfs:comment "The organization that offers and issues this certification program."@en .

cc:issues a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range cc:CertificationType ;
  owl:inverseOf cc:issuedBy ;
  rdfs:label "issues"@en ;
  rdfs:comment "Certification programs issued by this organization."@en .

# Certification holding properties

cc:certificationOf a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Certification ;
  rdfs:range cc:CertificationType ;
  owl:inverseOf cc:certificationHeldAs ;
  rdfs:label "certification of"@en ;
  rdfs:comment "The certification program (type) that this holding refers to."@en .

cc:certificationHeldAs a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:CertificationType ;
  rdfs:range cc:Certification ;
  owl:inverseOf cc:certificationOf ;
  rdfs:label "certification held as"@en ;
  rdfs:comment "A specific holding of this certification program."@en .

cc:hasPersonalCertification a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Person ;
  rdfs:range cc:PersonalCertification ;
  owl:inverseOf cc:personalCertificationOf ;
  rdfs:label "has personal certification"@en ;
  rdfs:comment "A professional certification holding by a person."@en .

cc:personalCertificationOf a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:PersonalCertification ;
  rdfs:range cc:Person ;
  owl:inverseOf cc:hasPersonalCertification ;
  rdfs:label "personal certification of"@en ;
  rdfs:comment "The person who holds this certification."@en .

cc:hasOrganizationalCertification a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range cc:OrganizationalCertification ;
  owl:inverseOf cc:organizationalCertificationOf ;
  rdfs:label "has organizational certification"@en ;
  rdfs:comment "A certification or accreditation holding by the organization."@en .

cc:organizationalCertificationOf a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:OrganizationalCertification ;
  rdfs:range cc:Organization ;
  owl:inverseOf cc:hasOrganizationalCertification ;
  rdfs:label "organizational certification of"@en ;
  rdfs:comment "The organization that holds this certification."@en .

cc:certificationLevel a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Certification ;
  rdfs:range skos:Concept ;
  rdfs:label "certification level"@en ;
  rdfs:comment "The proficiency level achieved by this holder: associate, professional, expert, or master."@en .

cc:credentialId a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Certification ;
  rdfs:range xsd:string ;
  rdfs:label "credential ID"@en ;
  rdfs:comment "The unique badge or credential ID assigned to this specific holder."@en .

cc:certificationUrl a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Certification ;
  rdfs:range xsd:anyURI ;
  rdfs:label "certification URL"@en ;
  rdfs:comment "URL to verify or view this specific holding online."@en .

# Project Properties

cc:projectStatus a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range skos:Concept ;
  rdfs:label "project status"@en ;
  rdfs:comment "Current status: ongoing, completed, paused or cancelled."@en .

cc:projectType a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range skos:Concept ;
  rdfs:label "project type"@en ;
  rdfs:comment "Classifies the project as client-commissioned, internal, open-source, or R&D."@en .

cc:requestedBy a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range cc:Organization ;
  owl:inverseOf cc:requestedProject ;
  rdfs:label "requested by"@en ;
  rdfs:comment "The client organization that requested the project."@en .

cc:requestedProject a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range cc:Project ;
  owl:inverseOf cc:requestedBy ;
  rdfs:label "requested project"@en ;
  rdfs:comment "A project requested by this organization."@en .

cc:developedBy a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range cc:Team ;
  owl:inverseOf cc:developsProject ;
  rdfs:label "developed by"@en ;
  rdfs:comment "The team responsible for developing the project."@en .

cc:developsProject a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Team ;
  rdfs:range cc:Project ;
  owl:inverseOf cc:developedBy ;
  rdfs:label "develops project"@en ;
  rdfs:comment "A project developed by this team."@en .

cc:usesTechnology a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range esco:Skill ;
  rdfs:label "uses technology"@en ;
  rdfs:comment "Technologies and frameworks used in the project."@en .

cc:projectManager a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range cc:Person ;
  owl:inverseOf cc:managesProject ;
  rdfs:label "project manager"@en ;
  rdfs:comment "The person managing the project."@en .

cc:managesProject a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Person ;
  rdfs:range cc:Project ;
  owl:inverseOf cc:projectManager ;
  rdfs:label "manages project"@en ;
  rdfs:comment "A project managed by this person."@en .


cc:hasProductionApp a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range xsd:anyURI ;
  rdfs:label "has production application"@en ;
  rdfs:comment "Link to the live/production application."@en .

cc:projectDomain a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range skos:Concept ;
  rdfs:label "project domain"@en ;
  rdfs:comment "The industry domain the project serves. Distinct from the executing organization's industry sector."@en .

cc:confidentialityLevel a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range skos:Concept ;
  rdfs:label "confidentiality level"@en ;
  rdfs:comment "Controls visibility of project information: public, internal, or confidential."@en .

cc:targetCountry a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range skos:Concept ;
  rdfs:label "target country"@en ;
  rdfs:comment "Countries where the project is deployed or used."@en .

cc:projectBudget a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range xsd:decimal ;
  rdfs:label "project budget"@en ;
  rdfs:comment "The allocated budget for the project."@en .

cc:projectEffort a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range xsd:integer ;
  rdfs:label "project effort"@en ;
  rdfs:comment "Estimated or actual effort in person-days."@en .


# GitHub Enrichment Properties

cc:workedFor a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Person ;
  rdfs:range cc:Organization ;
  rdfs:label "worked for"@en ;
  rdfs:comment "Inferred client organisations this person has contributed to via project work. Computed from GitHub contribution data; no inverse (computed, read-only)."@en .

cc:lastCommitDate a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:ProjectContribution ;
  rdfs:range xsd:date ;
  rdfs:label "last commit date"@en ;
  rdfs:comment "Date of the most recent commit in this contribution. Sourced from the GitHub stats API."@en .

cc:commitCount a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:ProjectContribution ;
  rdfs:range xsd:integer ;
  rdfs:label "commit count"@en ;
  rdfs:comment "Number of commits this person made to the project's GitHub repository. Sourced from the GitHub API."@en .

# Project Contribution Properties

cc:hasProjectContribution a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Person ;
  rdfs:range cc:ProjectContribution ;
  owl:inverseOf cc:contributionBy ;
  rdfs:label "has project contribution"@en ;
  rdfs:comment "A contribution this person made to a project."@en .

cc:contributionBy a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:ProjectContribution ;
  rdfs:range cc:Person ;
  owl:inverseOf cc:hasProjectContribution ;
  rdfs:label "contribution by"@en ;
  rdfs:comment "The person who made this contribution."@en .

cc:contributionTo a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:ProjectContribution ;
  rdfs:range cc:Project ;
  owl:inverseOf cc:projectHasContribution ;
  rdfs:label "contribution to"@en ;
  rdfs:comment "The project this contribution was made to."@en .

cc:projectHasContribution a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range cc:ProjectContribution ;
  owl:inverseOf cc:contributionTo ;
  rdfs:label "project has contribution"@en ;
  rdfs:comment "A contribution made to this project."@en .

cc:contributionRole a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:ProjectContribution ;
  rdfs:range skos:Concept ;
  rdfs:label "contribution role"@en ;
  rdfs:comment "The role played in this contribution."@en .

cc:contributionDescription a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:ProjectContribution ;
  rdfs:range xsd:string ;
  rdfs:label "contribution description"@en ;
  rdfs:comment "A description of the specific work done in this contribution. Useful for CV generation and portfolio presentation."@en .

cc:prReviewCount a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:ProjectContribution ;
  rdfs:range xsd:integer ;
  rdfs:label "PR review count"@en ;
  rdfs:comment "Number of pull requests reviewed by this person on the project repository. Sourced from the GitHub API. High review count relative to commit count is a signal of senior or mentoring activity."@en .

cc:mergedPrCount a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:ProjectContribution ;
  rdfs:range xsd:integer ;
  rdfs:label "merged PR count"@en ;
  rdfs:comment "Number of pull requests authored and merged by this person on the project repository. Sourced from the GitHub API. Measures completed deliverables as opposed to raw commit volume."@en .

cc:linesAdded a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:ProjectContribution ;
  rdfs:range xsd:integer ;
  rdfs:label "lines added"@en ;
  rdfs:comment "Total lines of code added by this person in the project repository across all commits. Sourced from the GitHub stats API."@en .

cc:linesDeleted a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:ProjectContribution ;
  rdfs:range xsd:integer ;
  rdfs:label "lines deleted"@en ;
  rdfs:comment "Total lines of code deleted by this person in the project repository across all commits. Sourced from the GitHub stats API."@en .

cc:isArchived a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range xsd:boolean ;
  rdfs:label "is archived"@en ;
  rdfs:comment "Whether the GitHub repository backing this project has been archived. Archived repositories are read-only; this signals a completed or abandoned project. Synced automatically from GitHub."@en .


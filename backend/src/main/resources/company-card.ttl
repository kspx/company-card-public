cc:languageSkillOf a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:LanguageSkill ;
  rdfs:range cc:Person ;
  owl:inverseOf cc:hasLanguageSkill ;

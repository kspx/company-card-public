cc:yearsOfExperience a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:SkillAssessment ;
  rdfs:range xsd:integer ;
  rdfs:label "years of experience"@en ;

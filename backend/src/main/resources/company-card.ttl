cc:proficiencyLevel a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:SkillAssessment ;
  rdfs:range skos:Concept ;
  rdfs:label "proficiency level"@en ;

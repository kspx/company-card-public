  rdfs:comment "A person who mentors this person."@en .

cc:mentors a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Person ;
  rdfs:range cc:Person ;
  owl:inverseOf cc:mentoredBy ;
  rdfs:label "mentors"@en ;
  rdfs:comment "A person mentored by this person."@en .

cc:nationality a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Person ;
  rdfs:range skos:Concept ;
  rdfs:label "nationality"@en ;

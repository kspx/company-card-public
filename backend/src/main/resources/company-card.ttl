@prefix cc:    <https://ontology.cogni.zone/company-card#> .
@prefix schema:<https://schema.org/> .
@prefix org:   <http://www.w3.org/ns/org#> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix rov:   <http://www.w3.org/ns/regorg#> .
@prefix locn:  <http://www.w3.org/ns/locn#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix esco:  <http://data.europa.eu/esco/model#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix adms:  <http://www.w3.org/ns/adms#> .
@prefix vann:  <http://purl.org/vocab/vann/> .

<https://ontology.cogni.zone/company-card#> a owl:Ontology ;
  owl:versionInfo "1.0.0" ;
  owl:versionIRI <https://ontology.cogni.zone/company-card/1.0.0#> ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:creator "Christina Spachiou"@en ;
  dcterms:publisher "Cognizone"@en ;
  dcterms:created "2025-08-15"^^xsd:date ;
  dcterms:modified "2026-02-07"^^xsd:date ;
  dcterms:title "Company Card Ontology"@en ;
  dcterms:description "An ontology for describing organizations, projects, teams, engagements, and people in a consultancy context. Built on top of ROV, ORG, DOAP, LOCN, ESCO, and aligned with Schema.org and SKOS. Pattern: curated reuse with local stubs (no full owl:imports)."@en ;
  rdfs:label "Company Card Ontology"@en ;
  rdfs:comment "Complete version including all vocabularies, employment tracking, and resource management properties."@en ;
  vann:preferredNamespacePrefix "cc" ;
  vann:preferredNamespaceUri "https://ontology.cogni.zone/company-card#" ;
  dcterms:conformsTo <http://www.w3.org/2002/07/owl#> ,
                     <http://www.w3.org/2004/02/skos/core#> .

#External term stubs

# FOAF
foaf:Agent a owl:Class ;
  rdfs:label "Agent (FOAF)"@en ;
  rdfs:comment "A person or organisation that acts in the world."@en .

# ORG / ROV
org:Organization a owl:Class ;
  rdfs:label "Organization (W3C ORG)"@en ;
  rdfs:comment "An organization such as a business, charity, government, or standards body."@en .

org:FormalOrganization a owl:Class ;
  rdfs:subClassOf org:Organization ;
  rdfs:label "Formal Organization (W3C ORG)"@en ;
  rdfs:comment "An organization recognized in the applicable legal jurisdiction, typically comprising a legal entity."@en .

rov:RegisteredOrganization a owl:Class ;
  rdfs:subClassOf org:FormalOrganization ;
  rdfs:label "Registered Organization (ROV)"@en ;
  rdfs:comment "An organization that gains legal entity status by the act of registration."@en .

org:OrganizationalUnit a owl:Class ;
  rdfs:subClassOf org:Organization ;
  rdfs:label "Organizational Unit"@en ;
  rdfs:comment "A subdivision of an organization such as a department, team, or office."@en .

rov:legalName a owl:DatatypeProperty ;
  rdfs:label "legal name"@en ;
  rdfs:comment "The legally registered name of the organization."@en .

rov:orgType a owl:ObjectProperty ;
  rdfs:label "organization type"@en ;
  rdfs:comment "The legal form of the organization."@en .

rov:orgStatus a owl:ObjectProperty ;
  rdfs:label "organization status"@en ;
  rdfs:comment "The operational status of the organization."@en .

rov:orgActivity a owl:ObjectProperty ;
  rdfs:label "economic activity"@en ;
  rdfs:comment "The NACE economic activity classification."@en .

rov:registration a owl:ObjectProperty ;
  rdfs:range adms:Identifier ;
  rdfs:label "registration"@en ;
  rdfs:comment "The official registration identifier that confers legal status."@en .

org:hasUnit a owl:ObjectProperty ;
  rdfs:label "has unit"@en ;
  rdfs:domain org:Organization ;
  rdfs:range org:OrganizationalUnit ;
  rdfs:comment "Indicates a unit which is part of this organization."@en .

org:unitOf a owl:ObjectProperty ;
  rdfs:label "unit of"@en ;
  rdfs:domain org:OrganizationalUnit ;
  rdfs:range org:Organization ;
  owl:inverseOf org:hasUnit ;
  rdfs:comment "Indicates the organization of which this unit is a part."@en .

# ADMS
adms:Identifier a owl:Class ;
  rdfs:label "Identifier (ADMS)"@en ;
  rdfs:comment "An identifier of an entity according to some identifier system."@en .

adms:identifier a owl:ObjectProperty ;
  rdfs:range adms:Identifier ;
  rdfs:label "identifier"@en ;
  rdfs:comment "Links an agent to an external identifier. The identifying system is given by dcterms:type, a ccv:IdentifierScheme concept."@en .

skos:notation a owl:DatatypeProperty ;
  rdfs:label "notation"@en ;
  rdfs:comment "The literal value of an identifier or classification code."@en .

skos:altLabel a owl:DatatypeProperty ;
  rdfs:label "alternate label"@en ;
  rdfs:comment "An alternative or trading name for a resource."@en .

dcterms:type a owl:ObjectProperty ;
  rdfs:label "type"@en ;
  rdfs:comment "On an adms:Identifier, the scheme it belongs to — a ccv:IdentifierScheme concept (ccv:SLACK, ccv:GITHUB)."@en .

dcterms:source a owl:ObjectProperty ;
  rdfs:range skos:Concept ;
  rdfs:label "source"@en ;
  rdfs:comment "The origin of a record — a ccv:ImportSource concept (ccv:SLACK, ccv:GITHUB, ccv:MANUAL, ccv:DERIVED). Set by the sync pipeline to track provenance."@en .

foaf:page a owl:ObjectProperty ;
  rdfs:label "page"@en ;
  rdfs:comment "A web page for the resource — on a GitHub adms:Identifier, the account's profile URL (https://github.com/{login})."@en .

# DOAP
doap:Project a owl:Class ;
  rdfs:label "Software Project (DOAP)"@en ;
  rdfs:comment "A software project."@en .

doap:name a owl:DatatypeProperty ;
  rdfs:label "name"@en ;
  rdfs:domain doap:Project ;
  rdfs:range xsd:string .

doap:description a owl:DatatypeProperty ;
  rdfs:label "description"@en ;
  rdfs:domain doap:Project ;
  rdfs:range xsd:string .

doap:repository a owl:DatatypeProperty ;
  rdfs:label "repository"@en ;
  rdfs:domain doap:Project ;
  rdfs:range xsd:anyURI .

doap:wiki a owl:DatatypeProperty ;
  rdfs:label "wiki"@en ;
  rdfs:domain doap:Project ;
  rdfs:range xsd:anyURI .

doap:homepage a owl:DatatypeProperty ;
  rdfs:label "homepage"@en ;
  rdfs:domain doap:Project ;
  rdfs:range xsd:anyURI .

doap:created a owl:DatatypeProperty ;
  rdfs:label "created"@en ;
  rdfs:domain doap:Project ;
  rdfs:range xsd:date ;
  rdfs:comment "Date when the project was created or initiated."@en .

doap:documentation a owl:DatatypeProperty ;
  rdfs:label "documentation"@en ;
  rdfs:domain doap:Project ;
  rdfs:range xsd:anyURI ;
  rdfs:comment "URL of project documentation."@en .

doap:bug-database a owl:DatatypeProperty ;
  rdfs:label "bug database"@en ;
  rdfs:domain doap:Project ;
  rdfs:range xsd:anyURI ;
  rdfs:comment "Bug tracker or issue tracker for the project."@en .

doap:license a owl:DatatypeProperty ;
  rdfs:label "license"@en ;
  rdfs:range xsd:anyURI ;
  rdfs:comment "The URI of an RDF description of the license the software is distributed under, as a SPDX reference."@en .

doap:programming-language a owl:DatatypeProperty ;
  rdfs:label "programming language"@en ;
  rdfs:domain doap:Project ;
  rdfs:range xsd:string ;
  rdfs:comment "Programming language a project is implemented in or primarily uses. Synced automatically from GitHub."@en .

# LOCN
locn:thoroughfare a owl:DatatypeProperty ;
  rdfs:label "thoroughfare"@en ;
  rdfs:comment "The street name and number."@en .

locn:postCode a owl:DatatypeProperty ;
  rdfs:label "post code"@en .

locn:postName a owl:DatatypeProperty ;
  rdfs:label "post name"@en ;
  rdfs:comment "The city or locality name."@en .

locn:adminUnitL1 a owl:ObjectProperty ;
  rdfs:range skos:Concept ;
  rdfs:label "admin unit L1"@en ;
  rdfs:comment "The country or top-level administrative division, as a ccv:Country concept."@en .

# ESCO
esco:Skill a owl:Class ;
  rdfs:label "Skill (ESCO)"@en ;
  rdfs:comment "A skill or competency from the European Skills, Competences, Qualifications and Occupations classification."@en .

esco:Occupation a owl:Class ;
  rdfs:label "Occupation (ESCO)"@en ;
  rdfs:comment "An occupation or job title from the European Skills, Competences, Qualifications and Occupations classification."@en .

# Schema.org
schema:description a owl:DatatypeProperty ;
  rdfs:label "description"@en .

schema:url a owl:DatatypeProperty ;
  rdfs:label "url"@en ;
  rdfs:range xsd:anyURI .

schema:email a owl:DatatypeProperty ;
  rdfs:label "email"@en .

schema:givenName a owl:DatatypeProperty ;
  rdfs:label "given name"@en .

schema:familyName a owl:DatatypeProperty ;
  rdfs:label "family name"@en .

schema:telephone a owl:DatatypeProperty ;
  rdfs:label "telephone"@en .

schema:foundingDate a owl:DatatypeProperty ;
  rdfs:label "founding date"@en ;
  rdfs:comment "The date the organization was created."@en .

schema:sameAs a owl:DatatypeProperty ;
  rdfs:label "same as"@en ;
  rdfs:range xsd:anyURI ;
  rdfs:comment "Links to external identifiers such as LinkedIn and ORCID."@en .

schema:Person a owl:Class ;
  rdfs:label "Person (Schema.org)"@en ;
  rdfs:comment "A person (alive, dead, undead, or fictional)."@en .

schema:EducationalOccupationalCredential a owl:Class ;
  rdfs:label "Educational Occupational Credential (Schema.org)"@en ;
  rdfs:comment "A credential awarded for educational achievement or occupational competence."@en .

schema:image a owl:DatatypeProperty ;
  rdfs:label "image"@en ;
  rdfs:range xsd:anyURI ;
  rdfs:comment "An image or photo URL."@en .

schema:keywords a owl:DatatypeProperty ;
  rdfs:label "keywords"@en ;
  rdfs:comment "Tags or topics describing a resource. On a cc:Project, the GitHub repository topics. Synced automatically from GitHub."@en .

schema:dateModified a owl:DatatypeProperty ;
  rdfs:range xsd:date ;
  rdfs:label "date modified"@en ;
  rdfs:comment "The date a resource was last modified. On a cc:Project, the date of the last push to the GitHub repository. Synced automatically from GitHub."@en .

schema:startDate a owl:DatatypeProperty ;
  rdfs:label "start date"@en ;
  rdfs:range xsd:date ;
  rdfs:comment "The start date of a temporal interval (employment, engagement, or contribution)."@en .

schema:endDate a owl:DatatypeProperty ;
  rdfs:label "end date"@en ;
  rdfs:range xsd:date ;
  rdfs:comment "The end date or expiry date of a temporal interval."@en .

schema:birthDate a owl:DatatypeProperty ;
  rdfs:label "birth date"@en ;
  rdfs:range xsd:date ;
  rdfs:comment "The date of birth of a person."@en .

# Form Annotation Properties

cc:createOnly a owl:AnnotationProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "create only"@en ;
  rdfs:comment "When true on a sh:property shape, the field is a sub-entity (no search input, only create-new button, hidden when creating the parent entity)."@en .

cc:noCreate a owl:AnnotationProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "no create"@en ;
  rdfs:comment "When true on a sh:property shape, the field is a reference or back-link (search shown, no create-new button)."@en .

cc:conceptScheme a owl:AnnotationProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "concept scheme"@en ;
  rdfs:comment "On a sh:property shape with sh:class skos:Concept, declares the SKOS concept scheme URI to fetch options from. Replaces the hardcoded property-to-scheme mapping in application config."@en .

cc:identifierPart a owl:AnnotationProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "identifier part"@en ;
  rdfs:comment "Boolean flag on a sh:property shape. When true, this property contributes to URI minting for new instances. Properties are combined in sh:order sequence. String values are used as-is; URI values use the local name."@en .

cc:computed a owl:AnnotationProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "computed"@en ;
  rdfs:comment "Boolean flag on a sh:property shape. When true, the field is derived or synced and shown read-only in the form, not user-editable."@en .

# Classes

cc:Organization a owl:Class ;
  rdfs:subClassOf rov:RegisteredOrganization ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Organization"@en ;
  rdfs:comment "An enterprise, consultancy, client, or partner organization."@en .

cc:Person a owl:Class ;
  rdfs:subClassOf schema:Person , foaf:Agent ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Person"@en ;
  rdfs:comment "An individual person, typically an employee, consultant, or contact."@en .

cc:Employment a owl:Class ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Employment"@en ;
  rdfs:comment "A person's employment or engagement with an organization. Captures role, dates, rate, and status per org."@en .

cc:Engagement a owl:Class ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Engagement"@en ;
  rdfs:comment "A business relationship between two organizations, with temporal metadata."@en .

cc:CertificationType a owl:Class ;
  rdfs:subClassOf schema:EducationalOccupationalCredential ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Certification Type"@en ;
  rdfs:comment "An abstract certification program or standard. Describes what the certification is, who issues it, and where to find it; shared across all holders."@en .

cc:Certification a owl:Class ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Certification"@en ;
  rdfs:comment "A specific certification holding: records that a particular person or organization holds a CertificationType, with issue/expiry dates, level, and credential ID. Use cc:PersonalCertification or cc:OrganizationalCertification."@en .

cc:PersonalCertification a owl:Class ;
  rdfs:subClassOf cc:Certification ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Personal Certification"@en ;
  rdfs:comment "A certification holding by an individual person."@en .

cc:OrganizationalCertification a owl:Class ;
  rdfs:subClassOf cc:Certification ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Organizational Certification"@en ;
  rdfs:comment "A certification or accreditation holding by an organization."@en .

cc:PersonalCertification owl:disjointWith cc:OrganizationalCertification .

cc:Project a owl:Class ;
  rdfs:subClassOf doap:Project ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Project"@en ;
  rdfs:comment "A project undertaken by an organization, typically for a client."@en .

cc:Team a owl:Class ;
  rdfs:subClassOf org:OrganizationalUnit ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Team"@en ;
  rdfs:comment "An internal team, unit, or department within an organization."@en .

cc:TeamMembership a owl:Class ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Team Membership"@en ;
  rdfs:comment "A reified relationship capturing a person's membership in a team, with start/end dates and role (leader/manager/member)."@en .

cc:ProjectContribution a owl:Class ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Project Contribution"@en ;
  rdfs:comment "A reified relationship capturing a person's contribution to a specific project, including the role they played."@en .

cc:SkillAssessment a owl:Class ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Skill Assessment"@en ;
  rdfs:comment "A reified relationship capturing a person's self-assessed or verified proficiency in a specific skill, including proficiency level and years of experience."@en .

cc:LanguageSkill a owl:Class ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Language Skill"@en ;
  rdfs:comment "A reified relationship capturing a person's proficiency in a language, with the CEFR level (A1–C2)."@en .

cc:Office a owl:Class ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:label "Office"@en ;
  rdfs:comment "A physical office location of an organization, with its own address."@en .

[] a owl:AllDisjointClasses ;
  owl:members (
    cc:Person
    cc:Organization
    cc:Project
    cc:Team
    cc:Employment
    cc:Engagement
    cc:CertificationType
    cc:Certification
    cc:ProjectContribution
    cc:SkillAssessment
    cc:LanguageSkill
    cc:TeamMembership
    cc:Office
  ) .

# Employment Model

cc:hasEmployment a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Person ;
  rdfs:range cc:Employment ;
  owl:inverseOf cc:employmentOf ;
  rdfs:label "has employment"@en ;
  rdfs:comment "A person's employment record at an organization."@en .

cc:employmentOf a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Employment ;
  rdfs:range cc:Person ;
  owl:inverseOf cc:hasEmployment ;
  rdfs:label "employment of"@en ;
  rdfs:comment "The person in this employment."@en .

cc:employmentWith a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Employment ;
  rdfs:range cc:Organization ;
  owl:inverseOf cc:employs ;
  rdfs:label "employment with"@en ;
  rdfs:comment "The organization employing the person."@en .

cc:employs a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range cc:Employment ;
  owl:inverseOf cc:employmentWith ;
  rdfs:label "employs"@en ;
  rdfs:comment "Employment records where this organization is the employer."@en .

cc:employmentType a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Employment ;
  rdfs:range skos:Concept ;
  rdfs:label "employment type"@en ;
  rdfs:comment "The type of employment: full-time, part-time, contractor, or freelancer."@en .

cc:employmentRole a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Employment ;
  rdfs:range esco:Occupation ;
  rdfs:label "employment role"@en ;
  rdfs:comment "Job title or role within the organization, from the ESCO Occupations taxonomy."@en .

cc:employmentRate a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Employment ;
  rdfs:range xsd:decimal ;
  rdfs:label "employment rate"@en ;
  rdfs:comment "Hourly or daily rate for this employment."@en .

cc:availabilityStatus a owl:ObjectProperty, owl:FunctionalProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Person ;
  rdfs:range skos:Concept ;
  rdfs:label "availability status"@en ;
  rdfs:comment "Current availability status of the person: available, on project, or on leave."@en .

cc:seniorityLevel a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Employment ;
  rdfs:range skos:Concept ;
  rdfs:label "seniority level"@en ;
  rdfs:comment "The person's seniority level: junior, mid-level, senior, lead, or principal."@en .

# Engagement Properties

cc:hasEngagement a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range cc:Engagement ;
  owl:inverseOf cc:engagementOf ;
  rdfs:label "has engagement"@en ;
  rdfs:comment "Links an organization to a business engagement."@en .

cc:engagementOf a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Engagement ;
  rdfs:range cc:Organization ;
  owl:inverseOf cc:hasEngagement ;
  rdfs:label "engagement of"@en ;
  rdfs:comment "The organization that has this engagement."@en .

cc:engagementWith a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Engagement ;
  rdfs:range cc:Organization ;
  owl:inverseOf cc:engagedIn ;
  rdfs:label "engagement with"@en ;
  rdfs:comment "The other organization in the engagement (client, partner, or vendor)."@en .

cc:engagedIn a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range cc:Engagement ;
  owl:inverseOf cc:engagementWith ;
  rdfs:label "engaged in"@en ;
  rdfs:comment "Engagements in which this organization is the other party (client, partner, or vendor)."@en .

cc:engagementType a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Engagement ;
  rdfs:range skos:Concept ;
  rdfs:label "engagement type"@en ;
  rdfs:comment "The type of engagement: client, partnership, or vendor."@en .

cc:engagementStatus a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Engagement ;
  rdfs:range skos:Concept ;
  rdfs:label "engagement status"@en ;
  rdfs:comment "Current status: prospective, active, paused, completed, or cancelled."@en .

cc:contractValue a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Engagement ;
  rdfs:range xsd:decimal ;
  rdfs:label "contract value"@en ;
  rdfs:comment "The total financial value of the engagement contract."@en .

# Organization Properties

cc:companySize a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range skos:Concept ;
  rdfs:label "company size"@en ;
  rdfs:comment "Classification of the organization's size."@en .

cc:operatesInCountry a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range skos:Concept ;
  rdfs:label "operates in country"@en ;
  rdfs:comment "Countries where the organization has operations (use EU Authority Table codes)."@en .

cc:offersServiceType a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range skos:Concept ;
  rdfs:label "offers service type"@en ;
  rdfs:comment "Types of services offered by the organization."@en .

cc:numberOfEmployees a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range xsd:integer ;
  rdfs:label "number of employees"@en ;
  rdfs:comment "Total number of employees in the organization."@en .

cc:hasOpenSourceRepo a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range xsd:anyURI ;
  rdfs:label "has open source repository"@en ;
  rdfs:comment "Link to an open source code repository maintained by the organization."@en .

cc:recruitingContact a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range cc:Person ;
  rdfs:label "recruiting contact"@en ;
  rdfs:comment "Primary contact person for recruitment inquiries."@en .

cc:hasOffice a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range cc:Office ;
  owl:inverseOf cc:officeOf ;
  rdfs:label "has office"@en ;
  rdfs:comment "Links an organization to one of its physical office locations."@en .

cc:officeOf a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Office ;
  rdfs:range cc:Organization ;
  owl:inverseOf cc:hasOffice ;
  rdfs:label "office of"@en ;
  rdfs:comment "Links an office to the organization it belongs to."@en .

cc:industrySector a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range skos:Concept ;
  rdfs:label "industry sector"@en ;
  rdfs:comment "High-level industry sector. For granular NACE classification use rov:orgActivity."@en .

cc:hasProject a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Organization ;
  rdfs:range cc:Project ;
  owl:inverseOf cc:projectOf ;
  rdfs:label "has project"@en ;
  rdfs:comment "A project executed or owned by this organization."@en .

cc:projectOf a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:Project ;
  rdfs:range cc:Organization ;
  owl:inverseOf cc:hasProject ;
  rdfs:label "project of"@en ;
  rdfs:comment "The organization that owns or executes this project."@en .

cc:hasTeam a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:subPropertyOf org:hasUnit ;
  rdfs:domain cc:Organization ;
  rdfs:range cc:Team ;
  owl:inverseOf cc:teamOf ;
  rdfs:label "has team"@en ;
  rdfs:comment "A team within the organization."@en .

cc:teamOf a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:subPropertyOf org:unitOf ;
  rdfs:domain cc:Team ;
  rdfs:range cc:Organization ;
  owl:inverseOf cc:hasTeam ;
  rdfs:label "team of"@en ;
  rdfs:comment "The organization this team belongs to."@en .

# CertificationType properties

cc:certificationName a owl:DatatypeProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:CertificationType ;
  rdfs:range xsd:string ;
  rdfs:label "certification name"@en ;

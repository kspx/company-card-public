cc:languageSpoken a owl:ObjectProperty ;
  rdfs:isDefinedBy <https://ontology.cogni.zone/company-card#> ;
  rdfs:domain cc:LanguageSkill ;
  rdfs:range skos:Concept ;
  rdfs:label "language spoken"@en ;

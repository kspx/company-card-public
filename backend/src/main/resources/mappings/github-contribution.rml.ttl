@prefix rr:     <http://www.w3.org/ns/r2rml#> .
@prefix rml:    <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:     <http://semweb.mmlab.be/ns/ql#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix cc:     <https://ontology.cogni.zone/company-card#> .

<https://ontology.cogni.zone/mappings/ContributionMapping>
    rml:logicalSource [
        rml:source "github-contribution.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$"
    ] ;

    rr:subjectMap [
        rr:template "https://data.cogni.zone/ProjectContribution/{contributionId}" ;
        rr:class cc:ProjectContribution
    ] ;

    rr:predicateObjectMap [
        rr:predicate cc:contributionBy ;
        rr:objectMap [ rml:reference "personUri" ; rr:termType rr:IRI ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate cc:contributionTo ;
        rr:objectMap [ rml:reference "projectUri" ; rr:termType rr:IRI ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate cc:contributionRole ;
        rr:objectMap [ rml:reference "contributionRole" ; rr:termType rr:IRI ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate cc:commitCount ;
        rr:objectMap [ rml:reference "commitCount" ; rr:datatype xsd:integer ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate cc:prReviewCount ;
        rr:objectMap [ rml:reference "prReviewCount" ; rr:datatype xsd:integer ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate cc:mergedPrCount ;
        rr:objectMap [ rml:reference "mergedPrCount" ; rr:datatype xsd:integer ]
    ] .

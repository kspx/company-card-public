@prefix rr:     <http://www.w3.org/ns/r2rml#> .
@prefix rml:    <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:     <http://semweb.mmlab.be/ns/ql#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix cc:     <https://ontology.cogni.zone/company-card#> .
@prefix schema: <https://schema.org/> .

<https://ontology.cogni.zone/mappings/PersonMapping>
    rml:logicalSource [
        rml:source "github-user.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$"
    ] ;

    rr:subjectMap [
        rr:template "https://data.cogni.zone/Person/{login}" ;
        rr:class cc:Person
    ] ;

    rr:predicateObjectMap [
        rr:predicate schema:givenName ;
        rr:objectMap [ rml:reference "givenName" ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate schema:familyName ;
        rr:objectMap [ rml:reference "familyName" ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate schema:image ;
        rr:objectMap [ rml:reference "avatarUrl" ; rr:datatype xsd:anyURI ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate schema:description ;
        rr:objectMap [ rml:reference "bio" ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate schema:email ;
        rr:objectMap [ rml:reference "email" ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate cc:basedInCity ;
        rr:objectMap [ rml:reference "location" ]
    ] .

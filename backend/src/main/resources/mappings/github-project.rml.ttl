@prefix rr:     <http://www.w3.org/ns/r2rml#> .
@prefix rml:    <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:     <http://semweb.mmlab.be/ns/ql#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix cc:     <https://ontology.cogni.zone/company-card#> .
@prefix doap:   <http://usefulinc.com/ns/doap#> .

<https://ontology.cogni.zone/mappings/ProjectMapping>
    rml:logicalSource [
        rml:source "github-repo.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$"
    ] ;

    rr:subjectMap [
        rr:template "https://data.cogni.zone/Project/{name}" ;
        rr:class cc:Project
    ] ;

    rr:predicateObjectMap [
        rr:predicate doap:name ;
        rr:objectMap [ rml:reference "name" ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate doap:description ;
        rr:objectMap [ rml:reference "description" ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate doap:repository ;
        rr:objectMap [
            rml:reference "htmlUrl" ;
            rr:datatype xsd:anyURI
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate doap:created ;
        rr:objectMap [
            rml:reference "createdAt" ;
            rr:datatype xsd:date
        ]
    ] .

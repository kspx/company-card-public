@prefix rr:     <http://www.w3.org/ns/r2rml#> .
@prefix rml:    <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:     <http://semweb.mmlab.be/ns/ql#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix cc:     <https://ontology.cogni.zone/company-card#> .
@prefix rov:    <http://www.w3.org/ns/regorg#> .
@prefix schema: <https://schema.org/> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix adms:   <http://www.w3.org/ns/adms#> .
@prefix ccv:    <https://ontology.cogni.zone/company-card-vocabularies#> .

<https://ontology.cogni.zone/mappings/SeedOrganizationMapping>
    rml:logicalSource [
        rml:source "known-organizations.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$[*]"
    ] ;

    rr:subjectMap [
        rr:template "https://data.cogni.zone/Organization/{id}" ;
        rr:class cc:Organization
    ] ;

    rr:predicateObjectMap [
        rr:predicate dct:identifier ;
        rr:objectMap [ rml:reference "id" ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate dct:source ;
        rr:objectMap [
            rr:constant ccv:MANUAL ;
            rr:termType rr:IRI
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate rov:legalName ;
        rr:objectMap [ rml:reference "legalName" ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate skos:altLabel ;
        rr:objectMap [ rml:reference "altLabel" ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate schema:description ;
        rr:objectMap [ rml:reference "description" ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate schema:url ;
        rr:objectMap [
            rml:reference "website" ;
            rr:datatype xsd:anyURI
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate schema:sameAs ;
        rr:objectMap [
            rml:reference "sameAs" ;
            rr:datatype xsd:anyURI
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate rov:orgType ;
        rr:objectMap [
            rml:reference "orgType" ;
            rr:termType rr:IRI
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate rov:orgStatus ;
        rr:objectMap [
            rml:reference "orgStatus" ;
            rr:termType rr:IRI
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate schema:foundingDate ;
        rr:objectMap [
            rml:reference "foundingDate" ;
            rr:datatype xsd:date
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate cc:numberOfEmployees ;
        rr:objectMap [
            rml:reference "numberOfEmployees" ;
            rr:datatype xsd:integer
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate cc:companySize ;
        rr:objectMap [
            rml:reference "companySize" ;
            rr:termType rr:IRI
        ]
    ] .

<https://ontology.cogni.zone/mappings/OrganizationRegistrationMapping>
    rml:logicalSource [
        rml:source "known-organizations.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$[?(@.lei)]"
    ] ;

    rr:subjectMap [
        rr:template "https://data.cogni.zone/Organization/{id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate rov:registration ;
        rr:objectMap [
            rr:template "https://data.cogni.zone/Identifier/lei-{lei}" ;
            rr:termType rr:IRI
        ]
    ] .

<https://ontology.cogni.zone/mappings/RegistrationIdentifierMapping>
    rml:logicalSource [
        rml:source "known-organizations.json" ;
        rml:referenceFormulation ql:JSONPath ;
        rml:iterator "$[?(@.lei)]"
    ] ;

    rr:subjectMap [
        rr:template "https://data.cogni.zone/Identifier/lei-{lei}" ;
        rr:class adms:Identifier
    ] ;

    rr:predicateObjectMap [
        rr:predicate skos:notation ;
        rr:objectMap [
            rml:reference "lei" ;
            rr:datatype xsd:string
        ]
    ] .

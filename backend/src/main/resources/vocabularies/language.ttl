@prefix ccv: <https://ontology.cogni.zone/company-card-vocabularies#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix language: <http://publications.europa.eu/resource/authority/language/> .

ccv:Language a skos:ConceptScheme ;
  skos:prefLabel "Language"@en ;
  dcterms:description "Languages spoken by personnel, curated for European IT consultancy context. Codes follow ISO 639-1."@en ;
  dcterms:source <http://publications.europa.eu/resource/authority/language> ;
  dcterms:created "2026-01-01"^^xsd:date ;
  skos:hasTopConcept language:ENG, language:FRA, language:NLD, language:DEU, language:SPA,
                     language:ITA, language:POR, language:ELL, language:POL, language:RON,
                     language:CES, language:HUN, language:BUL, language:HRV, language:SLK,
                     language:SLV, language:DAN, language:FIN, language:SWE, language:EST,
                     language:LAV, language:LIT, language:GLE, language:MLT,
                     language:RUS, language:UKR, language:TUR, language:ARA,
                     language:ZHO, language:JPN, language:KOR, language:HIN .


@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix nace2: <http://data.europa.eu/ux2/nace2/> .

nace2:nace2 a skos:ConceptScheme ;
  skos:prefLabel "NACE Rev. 2"@en ;
  dcterms:description "Statistical Classification of Economic Activities in the European Community, Rev. 2."@en ;
  dcterms:source <https://op.europa.eu/en/web/eu-vocabularies/concept-scheme/-/resource?uri=http://data.europa.eu/ux2/nace2/nace2> .

nace2:A a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Agriculture, forestry and fishing"@en ; skos:notation "A" .
nace2:B a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Mining and quarrying"@en ; skos:notation "B" .
nace2:C a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Manufacturing"@en ; skos:notation "C" .
nace2:D a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Electricity, gas, steam and air conditioning supply"@en ; skos:notation "D" .
nace2:E a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Water supply; sewerage, waste management and remediation activities"@en ; skos:notation "E" .
nace2:F a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Construction"@en ; skos:notation "F" .
nace2:G a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Wholesale and retail trade; repair of motor vehicles and motorcycles"@en ; skos:notation "G" .
nace2:H a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Transportation and storage"@en ; skos:notation "H" .
nace2:I a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Accommodation and food service activities"@en ; skos:notation "I" .
nace2:J a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Information and communication"@en ; skos:notation "J" .
nace2:K a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Financial and insurance activities"@en ; skos:notation "K" .
nace2:L a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Real estate activities"@en ; skos:notation "L" .
nace2:M a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Professional, scientific and technical activities"@en ; skos:notation "M" .
nace2:N a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Administrative and support service activities"@en ; skos:notation "N" .
nace2:O a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Public administration and defence; compulsory social security"@en ; skos:notation "O" .
nace2:P a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Education"@en ; skos:notation "P" .
nace2:Q a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Human health and social work activities"@en ; skos:notation "Q" .
nace2:R a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Arts, entertainment and recreation"@en ; skos:notation "R" .
nace2:S a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Other service activities"@en ; skos:notation "S" .
nace2:T a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Activities of households as employers; undifferentiated goods- and services-producing activities of households for own use"@en ; skos:notation "T" .
nace2:U a skos:Concept ; skos:inScheme nace2:nace2 ; skos:topConceptOf nace2:nace2 ;
  skos:prefLabel "Activities of extraterritorial organisations and bodies"@en ; skos:notation "U" .
